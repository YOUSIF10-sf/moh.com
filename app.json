{
  "expo": {
    "name": "Smart Warehouse",
    "slug": "smart-warehouse",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/smart-logo.png",
    "scheme": "mobileapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.yousiftariq.smartwarehouse",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      },
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/smart-logo.png",
        "backgroundImage": "./assets/images/smart-logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.yousiftariq.smartwarehouse"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/smart-logo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/smart-logo.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "902a195e-8c89-4b66-a371-e7066b2dbc81"
      }
    }
  }
}
